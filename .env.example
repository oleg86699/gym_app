# ──────────────────────────────────────────────────────────────────────
# Конфиг для локальной разработки.
# Скопируй этот файл в .env (он в .gitignore) и заполни реальными значениями.
#
#     cp .env.example .env
#
# ──────────────────────────────────────────────────────────────────────

# ─── Docker Compose ────────────────────────────────────────────────────
# Изолирует наш стек от других docker-compose проектов на машине.
# Если у тебя уже есть проект с именем gym_app — поменяй.
COMPOSE_PROJECT_NAME=gym_app

# ─── Часовой пояс ──────────────────────────────────────────────────────
TZ=Europe/Kyiv

# ─── Порты на хосте ────────────────────────────────────────────────────
# Нестандартные значения, чтобы не конфликтовать с другими проектами.
# Все сервисы биндятся только на 127.0.0.1 — наружу не торчат.
DB_PORT_HOST=25432
PGBOUNCER_PORT_HOST=26432
REDIS_PORT_HOST=26379
APP_PORT_HOST=28080
UI_PORT_HOST=25173
NGINX_PORT_HOST=28000

MINIO_API_PORT_HOST=29000
MINIO_CONSOLE_PORT_HOST=29001

# ─── Postgres ──────────────────────────────────────────────────────────
POSTGRES_DB=gym_app
POSTGRES_USER=gym_app
POSTGRES_PASSWORD=change_me_local_only

# DSN-ы для приложения. Используем pgbouncer как фронт для основного пула.
DATABASE_URL=postgresql+asyncpg://gym_app:change_me_local_only@pgbouncer:5432/gym_app
# Read replica на старте указывает туда же — см. ADR-011 категория Б.
DATABASE_READ_URL=postgresql+asyncpg://gym_app:change_me_local_only@pgbouncer:5432/gym_app

# ─── Redis ─────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── Celery + TaskIQ ───────────────────────────────────────────────────
# Celery — для тяжёлых long-running задач (постинг 1000 текстов и т.п.)
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
CELERY_WORKER_CONCURRENCY=2
# TaskIQ — для лёгких async задач (распаковка, валидация, scheduled jobs)
TASKIQ_BROKER_URL=redis://redis:6379/3
TASKIQ_RESULT_BACKEND=redis://redis:6379/4

# ─── MinIO ─────────────────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_me_strong_password

# ─── App / FastAPI ─────────────────────────────────────────────────────
ENVIRONMENT=dev
LOG_LEVEL=DEBUG
APP_PORT=8080

# JWT — обязательно сменить. Сгенерь: openssl rand -hex 32
JWT_SECRET=change_me_64_hex_chars_minimum_for_security_please
JWT_ALG=HS256
JWT_TTL_HOURS=24

# CORS origins (через запятую, без пробелов).
# В dev можно оставить пустым — UI ходит через nginx, same-origin.
ALLOWED_ORIGINS=

# Базовый URL UI для построения публичных ссылок (invite, password-reset).
# По умолчанию пусто = автоматически определяется из заголовка Host
# (работает с localhost:PORT, IP, доменом — что бы ни было в браузере).
#
# Задавай явно ТОЛЬКО для прод-сервера, если приложение доступно по
# нескольким хостам и ты хочешь, чтобы invite-ссылки всегда указывали
# на канонический адрес (защита от phishing: атакующий не сможет подделать
# Host-header так, чтобы invite указывал на чужой домен).
#
# Примеры:
#   PUBLIC_BASE_URL=                          # автодетект (default)
#   PUBLIC_BASE_URL=https://app.example.com   # явный канонический URL
PUBLIC_BASE_URL=

# ─── Super admin (создаётся seed-миграцией при первом старте) ──────────
SUPER_ADMIN_USERNAME=super_admin
SUPER_ADMIN_PASSWORD=change_me_strong_password
# опционально, можно заполнить в профиле позже
SUPER_ADMIN_EMAIL=

# ─── Backup ────────────────────────────────────────────────────────────
# По умолчанию каждые 48 часов в 03:30 по Europe/Kyiv.
BACKUP_CRON=30 3 */2 * *
# Раз в неделю в воскресенье в 04:00 — docker prune.
PRUNE_CRON=0 4 * * 0
RETENTION_DAYS=7

# ─── Лимиты приложения ─────────────────────────────────────────────────
MAX_ACTIVE_RUNS_PER_USER=15

# ─── SMTP (плейсхолдеры — заполнятся в этапе 3) ────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true

# ─── Шифрование секретов ───────────────────────────────────────────────
# Fernet key для wp_credentials.password (urlsafe base64, 32 bytes).
# Сгенерировать: python -c 'from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())'
# В prod обязательно. В dev — пусто = детерминистический dev-fallback с warning.
# ⚠ Потеря ключа = потеря всех зашифрованных паролей. Бекапить с БД.
WP_CRED_ENC_KEY=
